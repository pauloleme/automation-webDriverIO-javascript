{
  "name": "wdiodemoapp",
  "main": "expo-router/entry",
  "version": "2.2.0",
  "private": true,
  "scripts": {
    "android": "node scripts/build-android.js debug",
    "android:release": "node scripts/build-android.js release",
    "ios": "node scripts/build-ios.js debug",
    "ios:prebuild": "cd ios && pod install && cd ..",
    "ios:release": "node scripts/build-ios.js release",
    "prebuild": "expo prebuild",
    "prebuild:clean": "expo prebuild --clean",
    "lint": "eslint .",
    "start": "expo start --dev-client --clear",
    "test": "jest",
    "test:android": "wdio run wdio.android.app.conf.js",
    "version:patch": "node scripts/version.js patch",
    "version:minor": "node scripts/version.js minor",
    "version:major": "node scripts/version.js major",
    "version:custom": "node scripts/version.js custom",
    "wdio": "wdio run ./wdio.android.app.conf.js",
    "allure:generate": "npx allure generate ./allure-results -o ./allure-report --clean",
    "allure:clear": "if exist allure-results rmdir /s /q allure-results & if exist allure-report rmdir /s /q allure-report & if exist errorShots rmdir /s /q errorShots",
    "allure:open": "npx allure open ./allure-report",
    "allure:serve": "npx allure serve ./allure-results",
    "test:report": "npm run allure:clear && npm run wdio && npm run allure:serve"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/native": "^7.1.33",
    "expo": "~55.0.8",
    "expo-camera": "~55.0.10",
    "expo-constants": "~55.0.9",
    "expo-dev-client": "~55.0.18",
    "expo-font": "~55.0.4",
    "expo-linking": "~55.0.8",
    "expo-local-authentication": "^55.0.9",
    "expo-location": "~55.1.4",
    "expo-media-library": "~55.0.10",
    "expo-router": "~55.0.7",
    "expo-secure-store": "~55.0.9",
    "expo-splash-screen": "~55.0.12",
    "expo-sqlite": "~55.0.11",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-elements": "^3.4.3",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-picker-select": "^9.3.1",
    "react-native-reanimated": "4.2.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "~0.21.2",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "@wdio/allure-reporter": "^9.27.0",
    "@wdio/appium-service": "^9.27.0",
    "@wdio/cli": "^9.27.0",
    "@wdio/local-runner": "^9.27.0",
    "@wdio/mocha-framework": "^9.27.0",
    "@wdio/spec-reporter": "^9.27.0",
    "@wdio/visual-service": "^9.2.1",
    "allure": "^3.4.1",
    "allure-commandline": "^2.38.1",
    "appium-uiautomator2-driver": "^7.1.0",
    "expo-doctor": "^1.18.13",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.3",
    "wdio-wait-for": "^3.1.1"
  },
  "engines": {
    "node": ">=24"
  }
}
